# Cognee Service Configuration

# LLM Config
LLM_PROVIDER=ollama
LLM_ENDPOINT=http://host.minikube.internal:11434/v1
LLM_MODEL=qwen2.5-coder:7b
LLM_API_KEY=ollama

# Embedding Config
EMBEDDING_PROVIDER=ollama
EMBEDDING_ENDPOINT=http://host.minikube.internal:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Knowledge Graph (Neo4j)
GRAPH_DATABASE_URL=bolt://neo4j:7687
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=cloudnotes_graph_123

# Tokenization
HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5

# Pipeline Settings
COGNEE_SKIP_CONNECTION_TEST=true
